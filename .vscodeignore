# .vscodeignore - Files to exclude from extension packaging

# Development files
.git/
.gitignore
.github/
.vscode/
node_modules/*
!node_modules/axios/
!node_modules/axios/**/*
*.ts
!*.d.ts
src/
tsconfig.json
.mocharc*
*.test.*
test/
coverage/
nyc.config.js
.eslintrc*
.prettierrc*
.prettierignore
*.log

# Build artifacts
out/**/*.map
*.vsix
.DS_Store
Thumbs.db

# Documentation
README.md
CHANGELOG.md
TODO.md

# Test files
test/
*.test.*
**/*.test.*
**/test/
**/__tests__/
**/__mocks__/

# Source maps
**/*.map

# Development configuration files
.env*
.env.*
config.local.*
*.local.*